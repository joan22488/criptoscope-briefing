# ============================================================
# CRIPTOSCOPE BRIEFING - Configuración
# Copia este archivo como ".env" y rellena tus claves.
# NUNCA subas el .env a GitHub ni lo compartas.
# ============================================================

# --- Claude API (https://console.anthropic.com) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxx

# --- CoinDesk Data API (https://developers.coindesk.com) ---
# El plan gratuito es suficiente para empezar.
COINDESK_API_KEY=xxxxxxxxxxxxxxxxx

# --- Telegram Bot (créalo con @BotFather) ---
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxx
# ID del canal o chat donde publicar (ej: -1001234567890 para canales)
TELEGRAM_CHAT_ID=-100xxxxxxxxxx

# --- Configuración del briefing ---
# Hora de publicación (formato cron: minuto hora * * *)
# 0 7 * * *  =  todos los días a las 7:00
CRON_SCHEDULE=0 7 * * *
TIMEZONE=Europe/Madrid

# Instrumento principal que sigues (para funding, OI, precio)
MAIN_INSTRUMENT=ETH-USDT-VANILLA-PERPETUAL
FUTURES_MARKET=binance

# Modelo de Claude a usar (sonnet = buen equilibrio calidad/coste para uso diario)
CLAUDE_MODEL=claude-sonnet-4-6
